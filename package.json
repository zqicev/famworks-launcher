{
  "name": "famworks-launcher",
  "version": "1.1.2",
  "description": "FamWorks Minecraft Launcher",
  "author": "FamWorks",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && dotenv -e .env -- electron-builder --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "discord-rpc": "^4.0.1",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.8.9",
    "minecraft-launcher-core": "^3.8.0",
    "msmc": "^5.0.5",
    "prismarine-nbt": "^2.8.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/discord-rpc": "^4.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
